{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/webhook/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/health",
      "dest": "app.py"
    },
    {
      "src": "/",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/run_decay",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/proactive",
      "schedule": "*/30 * * * *"
    }
  ]
}
